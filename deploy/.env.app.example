# Per-app env template — copy to .env.prod / .env.dev / .env.preview
# and adjust values for each environment. chmod 600 before deploying.
# Do NOT place this in the root .env — that file is for Caddy vars only.

DATABASE_URL=sqlite:///app/kartoteka.db?mode=rwc
# Generate a random 32+ char secret for each environment independently:
# openssl rand -base64 32
OAUTH_SIGNING_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING
PUBLIC_BASE_URL=https://kartoteka.example.com
APP_ENV=production
BIND_ADDR=0.0.0.0:3000
RUST_LOG=info
