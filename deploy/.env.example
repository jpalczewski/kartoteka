# Root compose env (place at /srv/kartoteka/.env — Caddy reads KARTOTEKA_DOMAIN from here
# via environment: in compose.yml or docker compose --env-file)
KARTOTEKA_DOMAIN=kartoteka.example.com
# KARTOTEKA_PROD_TAG=v0.4.1   # uncomment to pin prod to a specific version

# Per-env files below. Copy to .env.prod / .env.dev / .env.preview and adjust.
# Set chmod 600 on each file before deploying.

DATABASE_URL=sqlite:///app/kartoteka.db?mode=rwc
OAUTH_SIGNING_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING
PUBLIC_BASE_URL=https://kartoteka.example.com
APP_ENV=production
BIND_ADDR=0.0.0.0:3000
RUST_LOG=info
