{
  "name": "kartoteka-gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "cp -r ../locales ./locales && cp ../locales/en/mcp.ftl ./locales/en/mcp.txt && cp ../locales/pl/mcp.ftl ./locales/pl/mcp.txt",
    "predev": "cp -r ../locales ./locales && cp ../locales/en/mcp.ftl ./locales/en/mcp.txt && cp ../locales/pl/mcp.ftl ./locales/pl/mcp.txt",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.1",
    "@fluent/bundle": "^0.18.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-auth": "^1.5.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.76.0"
  }
}
